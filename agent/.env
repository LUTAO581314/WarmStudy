DASHSCOPE_API_KEY=sk-14ddc07d28434828826acd058b5efb02
MINIMAX_API_KEY=sk-cp-oZ13uYhDN5gGkBgIzTG1qWLX5acK2VhDzcRk_LNWBIMOkgkRs3QegFI60fUVDi1QjLOcEEueHB6Q0QzUmq_kSKEYQBr4uT91UJxDnQRc1rLRZKibf_Sw0vI

# MiniMax 必需参数
MINIMAX_GROUP_ID=2034922294068908369  # MiniMax 控制台 → 群组ID

# 模型配置
CHAT_MODEL=minimax  # 聊天用 MiniMax (minimax) 或 DashScope (dashscope)

# Flask 配置
FLASK_ENV=production
DEBUG=false
SECRET_KEY=change_this_to_random_string

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Redis 配置 (可选，用于缓存)
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# MongoDB 配置 (可选，用于日志存储)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=rag_logs

# ChromaDB 配置
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=knowledge_base

# 向量搜索配置 (阿里云 DashScope)
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024

# 混合搜索配置
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3

# 缓存配置
QUERY_CACHE_SIZE=1000
EMBEDDING_CACHE_SIZE=2000

# 并发配置
MAX_WORKERS=8
BATCH_SIZE=50

# 监控配置
ENABLE_PROMETHEUS=true
METRICS_PORT=9090
# Redis 配置（生产级缓存+会话）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=300

# FastAPI 配置
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=5177
WORKERS=4

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
